+@echo off
+setlocal EnableExtensions EnableDelayedExpansion
+
+set "SCRIPT_DIR=%~dp0"
+set "DIST_FILE=%SCRIPT_DIR%dist\spicy-lyrics.js"
+set "BRIDGE_FILE=%SCRIPT_DIR%builds\spicy-lyrics.mjs"
+set "NODE_MODULES_DIR=%SCRIPT_DIR%node_modules"
+set "CREATOR_ENTRY=%SCRIPT_DIR%node_modules\@spicemod\creator\dist\bin.mjs"
+set "CREATOR_PACKAGE=%SCRIPT_DIR%node_modules\@spicemod\creator\package.json"
+set "REACT_PACKAGE=%SCRIPT_DIR%node_modules\react\package.json"
+set "KAWARP_PACKAGE=%SCRIPT_DIR%node_modules\@kawarp\core\package.json"
+set "EXTENSION_FILE_JS=spicy-lyrics.js"
+set "EXTENSION_FILE_MJS=spicy-lyrics.mjs"
+set "SKIP_BUILD="
+set "REQUIRE_BUILD="
+set "NO_PAUSE="
+set "BUN_EXE="
+set "SPICETIFY_CMD="
+
+:parse_args
+if "%~1"=="" goto args_done
+if /I "%~1"=="--skip-build" (
+  set "SKIP_BUILD=1"
+  shift
+  goto parse_args
+)
+if /I "%~1"=="--no-pause" (
+  set "NO_PAUSE=1"
+  shift
+  goto parse_args
+)
+if /I "%~1"=="--require-build" (
+  set "REQUIRE_BUILD=1"
+  shift
+  goto parse_args
+)
+shift
+goto parse_args
+
+:args_done
+
+echo.
+echo [1/6] Checking local tooling...
+
+if defined SPICETIFY_EXE (
+  if exist "%SPICETIFY_EXE%" (
+    set "SPICETIFY_CMD=%SPICETIFY_EXE%"
+  ) else (
+    echo [ERROR] SPICETIFY_EXE is set, but the file does not exist:
+    echo         "%SPICETIFY_EXE%"
+    goto finish_error
+  )
+)
+
+if not defined SPICETIFY_CMD (
+  where spicetify >nul 2>&1
+  if not errorlevel 1 (
+    set "SPICETIFY_CMD=spicetify"
+  )
+)
+
+if not defined SPICETIFY_CMD (
+  echo [ERROR] Spicetify is not available on PATH.
+  echo Install Spicetify first, then run this script again.
+  echo If Spicetify is installed in a custom location, set SPICETIFY_EXE to its full path and rerun the installer.
+  goto finish_error
+)
+
+pushd "%SCRIPT_DIR%" >nul 2>&1
+if errorlevel 1 (
+  echo [ERROR] Could not open the project directory.
+  goto finish_error
+)
+
+call :resolve_spicetify_dir
+set "SPICETIFY_CONFIG_FILE=%SPICETIFY_DIR%\config-xpui.ini"
+
+where bun >nul 2>&1
+if not errorlevel 1 (
+  set "BUN_EXE=bun"
+)
+if not defined BUN_EXE if exist "%USERPROFILE%\.bun\bin\bun.exe" (
+  set "BUN_EXE=%USERPROFILE%\.bun\bin\bun.exe"
+)
+
+if not defined SKIP_BUILD if exist "%SCRIPT_DIR%bun.lock" (
+  if defined BUN_EXE (
+    if exist "%SPICETIFY_CONFIG_FILE%" (
