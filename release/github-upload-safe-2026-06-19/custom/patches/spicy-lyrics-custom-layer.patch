+      if errorlevel 1 goto finish_error
+
+      echo [3/6] Building the latest Spicy Lyrics bundle...
+      call :build_bundle
+      if errorlevel 1 goto finish_error
+    ) else (
+      if defined REQUIRE_BUILD (
+        echo [ERROR] Spicetify config is missing:
