+  let contrast = 0;
+  let samples = 0;
+  const offsets = [
+    [-2, 0],
+    [2, 0],
+    [0, -2],
+    [0, 2],
+  ];
+
+  for (const [offsetX, offsetY] of offsets) {
+    const [nr, ng, nb] = samplePixel(sample, x + offsetX, y + offsetY);
+    const localLuma = (nr * 0.299 + ng * 0.587 + nb * 0.114) / 255;
+    contrast += Math.abs(baseLuma - localLuma);
+    samples += 1;
+  }
